{
  "name": "legal-ai-assistant",
  "version": "1.0.0",
  "description": "Assistente Jurídico/Compliance baseado em OpenClaw para o mercado brasileiro",
  "main": "index.js",
  "scripts": {
    "setup": "node scripts/setup.js",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/",
    "openclaw:install": "npm install -g openclaw",
    "openclaw:onboard": "openclaw onboard",
    "skills:install": "node scripts/install-skills.js",
    "monitor:start": "node services/diario-monitor/index.js",
    "api:start": "cd api && npm start",
    "dashboard:dev": "cd dashboard && npm run dev",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "deploy": "node scripts/deploy.js"
  },
  "keywords": [
    "legal",
    "compliance",
    "ai",
    "openclaw",
    "whatsapp",
    "telegram",
    "jurídico",
    "brasil"
  ],
  "author": "Seu Nome",
  "license": "PROPRIETARY",
  "dependencies": {
    "openclaw": "^1.0.0",
    "dotenv": "^16.4.5",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "pdf-parse": "^1.1.1",
    "node-cron": "^3.0.3",
    "telegraf": "^4.16.3",
    "twilio": "^5.0.0",
    "langchain": "^0.1.25",
    "@anthropic-ai/sdk": "^0.20.0",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "winston": "^3.11.0",
    "express": "^4.18.2",
    "fastify": "^4.26.2",
    "prisma": "^5.10.2"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.19",
    "nodemon": "^3.1.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
