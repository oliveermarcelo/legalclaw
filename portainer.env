# ============================================
# LegalClaw - Environment Variables
# Para usar no Portainer
# ============================================
#
# INSTRUÇÕES:
# 1. Portainer → Stacks → Add stack
# 2. Aba "Environment variables"
# 3. Cole estas variáveis (ou adicione manualmente)
# 4. Substitua os valores de exemplo
#
# ============================================

# ===== ANTHROPIC / CLAUDE =====
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===== TWILIO / WHATSAPP =====
# Obtenha em: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=+14155238886

# ===== TELEGRAM =====
# Obtenha em: @BotFather (Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Opcional: Restringir acesso (IDs separados por vírgula)
# Para descobrir seu ID, use: @userinfobot no Telegram
TELEGRAM_ALLOWED_USERS=

# ===== DATABASE =====
# IMPORTANTE: Troque a senha padrão!
DB_PASSWORD=SuaSenhaSeguraAqui123!@#

# ===== REDIS =====
# Opcional: Deixe vazio para sem senha
REDIS_PASSWORD=

# ===== MONITOR DE DIÁRIOS =====
# Palavras-chave para monitorar (separadas por vírgula)
DOU_KEYWORDS=sua empresa ltda,12.345.678/0001-90,processo 123456

# Horário de verificação (formato cron: min hora dia mês diasemana)
# Padrão: todo dia às 8h da manhã
DOU_CHECK_INTERVAL=0 8 * * *

# ===== CONFIGURAÇÕES GERAIS =====
# Ambiente (development, staging, production)
NODE_ENV=production

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# Porta da API (padrão: 3000)
API_PORT=3000

# ===== FEATURES HABILITADAS =====
ENABLE_CONTRACT_ANALYSIS=true
ENABLE_DIARIO_MONITOR=true
ENABLE_DEADLINE_MANAGER=true
ENABLE_JURISPRUDENCE_SEARCH=false
ENABLE_DOCUMENT_GENERATOR=false

# ===== LIMITES (OPCIONAL) =====
# Análises de contratos por mês (plano Solo)
PLAN_SOLO_MAX_CONTRACTS_MONTH=50

# Pesquisas de jurisprudência por mês (plano Solo)
PLAN_SOLO_MAX_SEARCHES_MONTH=100

# ===== NOTIFICAÇÕES (OPCIONAL) =====
# SMTP para envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app

# ===== MONITORAMENTO (OPCIONAL) =====
# Sentry (rastreamento de erros)
SENTRY_DSN=

# Datadog (métricas)
DATADOG_API_KEY=

# ===== BACKUP (OPCIONAL) =====
# AWS S3 para backup
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=legalclaw-backups

# ===== DESENVOLVIMENTO =====
# Apenas para debug (remova em produção)
DEBUG=legalclaw:*

# ============================================
# EXEMPLO DE USO NO PORTAINER:
# ============================================
#
# Método 1: Advanced mode (recomendado)
# ------------------------------------
# 1. Environment variables → Advanced mode
# 2. Cole tudo acima
# 3. Edite os valores
#
# Método 2: Simple mode
# ---------------------
# 1. Adicione uma por uma:
#    Name: ANTHROPIC_API_KEY
#    Value: sk-ant-api03-xxxxx
#
# ============================================
