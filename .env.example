# ==============================================
# DrLex - Variaveis de Ambiente
# Copie para .env e preencha com suas credenciais
# ==============================================

NODE_ENV=production
PORT=3000

# ---- IA (escolher provider) ----
AI_PROVIDER=anthropic  # 'anthropic' ou 'gemini'

# Anthropic Claude (recomendado)
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini (alternativa)
# GEMINI_API_KEY=sua-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash

# ---- Banco de Dados ----
DATABASE_URL=postgresql://drlex:drlex_secret@drlex_postgres:5432/drlex
DB_PASSWORD=drlex_secret

# ---- Redis ----
REDIS_URL=redis://drlex_redis:6379

# ---- Evolution API (WhatsApp) ----
EVOLUTION_API_URL=https://api.wapify.com.br
EVOLUTION_API_KEY=sua-evolution-api-key
EVOLUTION_INSTANCE=drlex
EVOLUTION_WEBHOOK_URL=https://drlex.wapify.com.br/webhooks/evolution

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=seu-token-aqui

# ---- JWT ----
JWT_SECRET=gere-um-hash-seguro-aqui
