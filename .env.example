# ==============================================
# DrLex - Variaveis de Ambiente
# Copie para .env e preencha com suas credenciais
# ==============================================

NODE_ENV=production
PORT=3000

# ---- IA (escolher provider) ----
# Opcoes: openai | anthropic | gemini
AI_PROVIDER=openai

# OpenAI (gpt-4o-mini)
OPENAI_API_KEY=sk-sua-chave-openai-aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_ALLOWED_MODELS=gpt-4o-mini,gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
# Quando texto do contrato/PDF exceder esse tamanho, sobe para gpt-4o automaticamente
OPENAI_AUTO_ESCALATE_CHARS=18000

# Anthropic Claude (recomendado)
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_ALLOWED_MODELS=claude-sonnet-4-20250514

# Gemini (alternativa)
# GEMINI_API_KEY=sua-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_ALLOWED_MODELS=gemini-2.0-flash

# ---- Banco de Dados ----
DATABASE_URL=postgresql://drlex:drlex_secret@drlex_postgres:5432/drlex
DB_PASSWORD=drlex_secret

# ---- Redis ----
REDIS_URL=redis://drlex_redis:6379

# ---- Evolution API (WhatsApp) ----
EVOLUTION_API_URL=https://api.wapify.com.br
EVOLUTION_API_KEY=sua-evolution-api-key
EVOLUTION_INSTANCE=drlex
EVOLUTION_WEBHOOK_URL=https://drlex.wapify.com.br/webhooks/evolution

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=seu-token-aqui

# ---- Consultas Externas Juridicas (Escavador) ----
EXTERNAL_LEGAL_PROVIDER=escavador
ESCAVADOR_ENABLED=false
ESCAVADOR_API_KEY=sua-chave-escavador-aqui
ESCAVADOR_BASE_URL=https://api.escavador.com
ESCAVADOR_TIMEOUT_MS=20000
ESCAVADOR_MAX_PER_PAGE=50

# ---- JWT ----
JWT_SECRET=gere-um-hash-seguro-aqui
