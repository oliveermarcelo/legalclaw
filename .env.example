# ========================================
# LEGALCLAW - Configurações de Ambiente
# ========================================

# ---------------
# OpenClaw Config
# ---------------
OPENCLAW_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here # Opcional

# Modelo padrão
OPENCLAW_MODEL=claude-sonnet-4-5-20250929

# ---------------
# Messaging
# ---------------

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
WHATSAPP_VERIFIED_NUMBERS=+5511999999999,+5521888888888

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ALLOWED_USERS=user_id_1,user_id_2

# ---------------
# Database
# ---------------
DATABASE_URL=postgresql://user:password@localhost:5432/legalclaw
REDIS_URL=redis://localhost:6379

# ---------------
# Serviços Jurídicos
# ---------------

# Diários Oficiais
DOU_API_KEY=your_dou_api_key # Se disponível
DOU_CHECK_INTERVAL=0 8 * * * # Cron: todo dia às 8h

# JusBrasil (opcional)
JUSBRASIL_API_KEY=your_jusbrasil_key

# Tribunais
STF_API_URL=https://portal.stf.jus.br/servicos/
STJ_API_URL=https://www.stj.jus.br/sites/portalp/

# ---------------
# Storage
# ---------------
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
S3_BUCKET=legalclaw-documents

# ---------------
# Email (Notificações)
# ---------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@legalclaw.com.br
SMTP_PASS=your_email_password
NOTIFICATION_EMAIL_FROM=LegalClaw <noreply@legalclaw.com.br>

# ---------------
# API
# ---------------
API_PORT=3000
API_SECRET_KEY=your_super_secret_key_here_min_32_chars
JWT_SECRET=another_super_secret_for_jwt_tokens
API_RATE_LIMIT=100 # requests por minuto

# ---------------
# Dashboard
# ---------------
DASHBOARD_PORT=3001
DASHBOARD_URL=http://localhost:3001
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3001

# ---------------
# Monitoring
# ---------------
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
LOG_LEVEL=info # debug, info, warn, error
DATADOG_API_KEY=your_datadog_key # Opcional

# ---------------
# Features
# ---------------
ENABLE_CONTRACT_ANALYSIS=true
ENABLE_DIARIO_MONITOR=true
ENABLE_DEADLINE_MANAGER=true
ENABLE_JURISPRUDENCE_SEARCH=true
ENABLE_DOCUMENT_GENERATOR=true

# ---------------
# Limites por Plano
# ---------------
# Solo
PLAN_SOLO_MAX_INSTANCES=1
PLAN_SOLO_MAX_CONTRACTS_MONTH=50
PLAN_SOLO_MAX_SEARCHES_MONTH=100

# Escritório
PLAN_ESCRITORIO_MAX_INSTANCES=3
PLAN_ESCRITORIO_MAX_CONTRACTS_MONTH=200
PLAN_ESCRITORIO_MAX_SEARCHES_MONTH=500

# Enterprise
PLAN_ENTERPRISE_MAX_INSTANCES=-1 # Ilimitado
PLAN_ENTERPRISE_MAX_CONTRACTS_MONTH=-1
PLAN_ENTERPRISE_MAX_SEARCHES_MONTH=-1

# ---------------
# Desenvolvimento
# ---------------
NODE_ENV=development # production, staging, development
DEBUG=legalclaw:* # Logs detalhados

# ---------------
# Segurança
# ---------------
ENCRYPTION_KEY=your_32_char_encryption_key_here
ENABLE_2FA=true
SESSION_TIMEOUT=3600 # segundos

# ---------------
# Backup
# ---------------
BACKUP_ENABLED=true
BACKUP_INTERVAL=0 2 * * * # Cron: todo dia às 2h
BACKUP_RETENTION_DAYS=30
